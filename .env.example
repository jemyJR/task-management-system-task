PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/task-management-system-task-db
DB_USER=admin
DB_PASSWORD=change_me
DB_HOST=mongo
DB_PORT=27017
DB_OPTIONS=retryWrites=true&w=majority&appName=task-management-system-task-db&authSource=admin

# JWT
ACCESS_TOKEN_SECRET=replace_with_strong_access_secret
REFRESH_TOKEN_SECRET=replace_with_strong_refresh_secret
ACCESS_TOKEN_EXPIRY=5m
REFRESH_TOKEN_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Logging
ENABLE_DB_LOGGING=false
LOG_LEVEL=debug
